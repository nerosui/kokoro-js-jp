{
  "name": "kokoro-js-jp",
  "version": "0.1.1",
  "type": "module",
  "exports": {
    "types": "./dist/index.d.ts",
    "default": "./dist/index.js"
  },
  "bin": {
    "kokoro-js-jp-copy-assets": "scripts/copy-assets.mjs"
  },
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "node scripts/build.mjs",
    "prepack": "npm run typecheck && npm run build",
    "format": "prettier --write . --print-width 1000",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "kokoro",
    "tts",
    "text-to-speech",
    "japanese",
    "open-jtalk",
    "browser",
    "wasm"
  ],
  "author": {
    "name": "nerosui"
  },
  "license": "Apache-2.0",
  "description": "Browser-based English + Japanese TTS: kokoro-js (Kokoro-82M via transformers.js/ONNX) + openjtalkjs (Open JTalk G2P, WASM). No server or container required.",
  "dependencies": {
    "@huggingface/transformers": "^3.5.1",
    "kokoro-js": "^1.2.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "prettier": "^3.9.6",
    "rollup": "^4.62.2",
    "tslib": "^2.8.1",
    "typescript": "^5.6.0",
    "vitest": "^4.1.10"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "THIRD_PARTY_NOTICES.md",
    "scripts/copy-assets.mjs"
  ],
  "homepage": "https://github.com/nerosui/kokoro-js-jp",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nerosui/kokoro-js-jp.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  }
}
